{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile information.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "currentSignal": { "type": "string", "enum": ["green", "orange", "red"] },
        "partnerId": { "type": "string" },
        "coupleId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "createdAt"]
    },
    "PartnerInvite": {
      "title": "PartnerInvite",
      "type": "object",
      "description": "An invitation sent from one user to another to couple accounts.",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderEmail": { "type": "string" },
        "receiverEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "declined"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "receiverEmail", "status", "createdAt"]
    },
    "Couple": {
      "title": "Couple",
      "type": "object",
      "description": "Represents a bond between two users.",
      "properties": {
        "id": { "type": "string" },
        "uids": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "uids", "createdAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "type": "object",
      "description": "A message sent between partners.",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "text", "createdAt"]
    },
    "Goal": {
      "title": "Goal",
      "type": "object",
      "description": "An objective or habit a user is tracking.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "progress": { "type": "number" },
        "shared": { "type": "boolean" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "progress", "createdAt"]
    },
    "ForumPost": {
      "title": "ForumPost",
      "type": "object",
      "description": "A post in the community forum.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userDisplayName": { "type": "string" },
        "userPhotoUrl": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "likes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "content", "createdAt"]
    },
    "GratitudeWin": {
      "title": "GratitudeWin",
      "type": "object",
      "description": "A user's daily win or gratitude entry.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "text", "createdAt"]
    },
    "EmotionalEpisode": {
      "title": "EmotionalEpisode",
      "type": "object",
      "description": "An emotional state tracking entry.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "intensity": { "type": "number" },
        "trigger": { "type": "string" },
        "notes": { "type": "string" },
        "isAnonymized": { "type": "boolean" },
        "aiInsights": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "intensity", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data."
    },
    "/invites/{inviteId}": {
      "schema": "PartnerInvite",
      "description": "Global invites collection."
    },
    "/couples/{coupleId}": {
      "schema": "Couple",
      "description": "Shared couple data."
    },
    "/couples/{coupleId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Real-time messages for a couple."
    },
    "/goals/{goalId}": {
      "schema": "Goal",
      "description": "User goals and habits."
    },
    "/forum-posts/{postId}": {
      "schema": "ForumPost",
      "description": "Community discussion posts."
    },
    "/gratitude/{winId}": {
      "schema": "GratitudeWin",
      "description": "Daily wins and gratitude entries."
    },
    "/episodes/{episodeId}": {
      "schema": "EmotionalEpisode",
      "description": "Emotional tracking logs."
    }
  }
}