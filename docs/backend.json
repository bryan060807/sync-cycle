
{
  "entities": {
    "Episode": {
      "title": "Episode",
      "description": "A recorded emotional episode for BPD tracking.",
      "type": "object",
      "properties": {
        "intensity": { "type": "number", "description": "Intensity level from 1-10." },
        "trigger": { "type": "string", "description": "What triggered the episode." },
        "notes": { "type": "string", "description": "Additional context or thoughts." },
        "copingSkillId": { "type": "string", "description": "ID of the coping skill used." },
        "userId": { "type": "string", "description": "UID of the user who logged the episode." },
        "createdAt": { "type": "string", "format": "date-time" },
        "isAnonymized": { "type": "boolean" }
      },
      "required": ["intensity", "userId", "createdAt"]
    },
    "Goal": {
      "title": "Goal",
      "description": "A personal or shared goal.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "targetDate": { "type": "string" },
        "isMutual": { "type": "boolean" },
        "progress": { "type": "number" },
        "userId": { "type": "string" },
        "coupleId": { "type": "string" }
      },
      "required": ["title", "userId", "progress"]
    },
    "List": {
      "title": "List",
      "description": "A collection of items/tasks.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "userId", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial record for retro analysis.",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "type", "userId", "createdAt"]
    },
    "Gratitude": {
      "title": "Gratitude",
      "description": "A win or gratitude note for a partner.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "userId", "createdAt"]
    },
    "HealthMetric": {
      "title": "HealthMetric",
      "description": "Vital signs and health data.",
      "type": "object",
      "properties": {
        "weight": { "type": "number" },
        "systolic": { "type": "number" },
        "diastolic": { "type": "number" },
        "bloodSugar": { "type": "number" },
        "pulseRate": { "type": "number" },
        "notes": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "createdAt"]
    },
    "Medication": {
      "title": "Medication",
      "description": "Prescription and supplement tracking.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "dosage": { "type": "string" },
        "schedule": { "type": "string" },
        "frequency": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "dosage", "userId", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User alert or update.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "type": { "type": "string", "enum": ["alert", "system", "social"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "createdAt"]
    },
    "ForumPost": {
      "title": "ForumPost",
      "description": "Community discussion post.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userDisplayName": { "type": "string" },
        "userPhotoUrl": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "likes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "content", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/episodes/{episodeId}": {
      "schema": "#/entities/Episode",
      "description": "User emotional episodes."
    },
    "/goals/{goalId}": {
      "schema": "#/entities/Goal",
      "description": "Shared and personal goals."
    },
    "/lists/{listId}": {
      "schema": "#/entities/List",
      "description": "Task and item lists."
    },
    "/transactions/{transactionId}": {
      "schema": "#/entities/Transaction",
      "description": "Financial records."
    },
    "/gratitude/{gratitudeId}": {
      "schema": "#/entities/Gratitude",
      "description": "Wins and gratitude notes."
    },
    "/health-metrics/{metricId}": {
      "schema": "#/entities/HealthMetric",
      "description": "Health data entries."
    },
    "/medications/{medicationId}": {
      "schema": "#/entities/Medication",
      "description": "User medications and supplements."
    },
    "/notifications/{notificationId}": {
      "schema": "#/entities/Notification",
      "description": "User notifications."
    },
    "/forum-posts/{postId}": {
      "schema": "#/entities/ForumPost",
      "description": "Community forum posts."
    }
  }
}
