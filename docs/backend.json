
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile information.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "partnerId": { "type": "string", "description": "UID of the connected partner." },
        "coupleId": { "type": "string", "description": "ID of the shared couple document." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "createdAt", "updatedAt"]
    },
    "PartnerInvite": {
      "title": "PartnerInvite",
      "type": "object",
      "description": "An invitation sent from one user to another to couple accounts.",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderEmail": { "type": "string" },
        "receiverEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "declined"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "senderEmail", "receiverEmail", "status", "createdAt"]
    },
    "Couple": {
      "title": "Couple",
      "type": "object",
      "description": "Represents a bond between two users.",
      "properties": {
        "id": { "type": "string" },
        "uids": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "uids", "createdAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "type": "object",
      "description": "A message sent between partners.",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "text", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "User profile data."
        }
      },
      {
        "path": "/invites/{inviteId}",
        "definition": {
          "entityName": "PartnerInvite",
          "schema": { "$ref": "#/backend/entities/PartnerInvite" },
          "description": "Global invites collection for finding invites by receiverEmail."
        }
      },
      {
        "path": "/couples/{coupleId}",
        "definition": {
          "entityName": "Couple",
          "schema": { "$ref": "#/backend/entities/Couple" },
          "description": "Shared couple data."
        }
      },
      {
        "path": "/couples/{coupleId}/messages/{messageId}",
        "definition": {
          "entityName": "ChatMessage",
          "schema": { "$ref": "#/backend/entities/ChatMessage" },
          "description": "Real-time messages for a couple."
        }
      }
    ]
  }
}
