rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- FULL OPEN ACCESS FOR PROTOTYPING ---
    // Updated at: 2024-03-24T12:00:00Z
    // This allows anyone to read and write all data without authentication.
    match /{document=**} {
      allow read, write: if true;
    }

    // Explicitly allow list operations for collections that were throwing errors
    match /gratitude/{document=**} {
      allow read, write: if true;
    }
    
    match /episodes/{document=**} {
      allow read, write: if true;
    }

    match /goals/{document=**} {
      allow read, write: if true;
    }
  }
}