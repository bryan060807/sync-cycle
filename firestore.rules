rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDocOwner(data) {
      return isSignedIn() && data.userId == request.auth.uid;
    }

    // --- Collection Rules ---

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Forum Posts
    match /forum-posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        (resource.data.userId == request.auth.uid) || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']))
      );
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Emotional Episodes
    match /episodes/{episodeId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.isAnonymized == true
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isDocOwner(resource.data);
    }

    // Health Metrics
    match /health-metrics/{metricId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isDocOwner(resource.data);
    }

    // Medications
    match /medications/{medId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isDocOwner(resource.data);
    }

    // Gratitude / Wins
    match /gratitude/{winId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isDocOwner(resource.data);
    }

    // Goals
    match /goals/{goalId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.shared == true
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isDocOwner(resource.data);
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isDocOwner(resource.data);
    }

    // Lists & Collections
    match /lists/{listId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isDocOwner(resource.data);
    }

    // Partner Invites
    match /invites/{inviteId} {
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow read: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        (request.auth.token.email != null && resource.data.receiverEmail == request.auth.token.email)
      );
      allow update: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        (request.auth.token.email != null && resource.data.receiverEmail == request.auth.token.email)
      );
      allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
    }

    // Couples & Shared Data
    match /couples/{coupleId} {
      allow read, update: if isSignedIn() && request.auth.uid in resource.data.uids;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.uids;
      
      match /messages/{messageId} {
        allow read, list, create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.uids;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}