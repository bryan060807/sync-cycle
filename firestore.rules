rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDataOwner() {
      return isSignedIn() && request.auth.uid == resource.data.userId;
    }

    function isRequestOwner() {
      return isSignedIn() && request.auth.uid == request.resource.data.userId;
    }

    // --- Collection Rules ---

    // User Profiles
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // Forum Posts: Signed-in users can read and create. Only owner can update/delete.
    match /forum-posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        (resource.data.userId == request.auth.uid) || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']))
      );
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Emotional Episodes (Wellness)
    match /episodes/{episodeId} {
      allow read, list: if isDataOwner();
      allow create: if isRequestOwner();
      allow update, delete: if isDataOwner();
    }

    // Health Metrics
    match /health-metrics/{metricId} {
      allow read, list: if isDataOwner();
      allow create: if isRequestOwner();
      allow update, delete: if isDataOwner();
    }

    // Medications
    match /medications/{medId} {
      allow read, list: if isDataOwner();
      allow create: if isRequestOwner();
      allow update, delete: if isDataOwner();
    }

    // Gratitude / Wins
    match /gratitude/{winId} {
      allow read, list: if isDataOwner();
      allow create: if isRequestOwner();
      allow update, delete: if isDataOwner();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read, list: if isDataOwner();
      allow create: if isRequestOwner();
      allow update, delete: if isDataOwner();
    }

    // Lists & Collections
    match /lists/{listId} {
      allow read, list: if isDataOwner();
      allow create: if isRequestOwner();
      allow update, delete: if isDataOwner();
    }

    // Partner Invites
    match /invites/{inviteId} {
      allow read, list: if isSignedIn() && (
        request.auth.uid == resource.data.senderId || 
        request.auth.token.email == resource.data.receiverEmail
      );
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.senderId || 
        request.auth.token.email == resource.data.receiverEmail
      );
      allow delete: if isSignedIn() && request.auth.uid == resource.data.senderId;
    }

    // Couples & Shared Data
    match /couples/{coupleId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.uids;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.uids;
      allow update: if isSignedIn() && request.auth.uid in resource.data.uids;
      
      match /messages/{messageId} {
        allow read, list: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.uids;
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.uids;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}