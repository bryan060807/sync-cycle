rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    // User Profiles: Users can manage their own profile
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Generic rule for personal data collections
    // This covers: episodes, gratitude, goals, health-metrics, medications, lists, notifications
    match /episodes/{id} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /gratitude/{id} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /goals/{id} {
      // Allow reading if owner OR if shared (shared goals still need a userId for the query)
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.shared == true);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /health-metrics/{id} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /medications/{id} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /lists/{id} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /notifications/{id} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Forum Posts: Community readable, owner writable
    match /forum-posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Partner Invites
    match /invites/{inviteId} {
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow read, update: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        (request.auth.token.email != null && resource.data.receiverEmail == request.auth.token.email)
      );
      allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
    }

    // Couples & Shared Data
    match /couples/{coupleId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.uids;
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && request.auth.uid in resource.data.uids;
      
      match /messages/{messageId} {
        allow read, create: if isSignedIn();
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}