rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Permissive Rules for Prototyping ---
    // This allows any authenticated user to read and write any document.
    // This is intended to unblock development and resolve 'Missing or insufficient permissions' errors.
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Default deny for unauthenticated users
    match /{document=**} {
      allow read, write: if false;
    }
  }
}