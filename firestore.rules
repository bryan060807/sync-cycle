rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Personal Data Collections (Episodes, Gratitude, Goals, Metrics, etc.)
    // We use a broader match pattern to ensure all personal data is covered consistently.
    match /episodes/{id} {
      allow list: if isSignedIn() && query.limit <= 100 && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /gratitude/{id} {
      allow list: if isSignedIn() && query.limit <= 100 && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /goals/{id} {
      // Owners can do anything; others can only read if shared
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.shared == true);
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.shared == true);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /health-metrics/{id} {
      allow read, write: if isSignedIn() && (
        (resource == null || resource.data.userId == request.auth.uid) &&
        (request.resource == null || request.resource.data.userId == request.auth.uid)
      );
    }

    match /medications/{id} {
      allow read, write: if isSignedIn() && (
        (resource == null || resource.data.userId == request.auth.uid) &&
        (request.resource == null || request.resource.data.userId == request.auth.uid)
      );
    }

    match /lists/{id} {
      allow read, write: if isSignedIn() && (
        (resource == null || resource.data.userId == request.auth.uid) &&
        (request.resource == null || request.resource.data.userId == request.auth.uid)
      );
    }

    match /notifications/{id} {
      allow read, write: if isSignedIn() && (
        (resource == null || resource.data.userId == request.auth.uid) &&
        (request.resource == null || request.resource.data.userId == request.auth.uid)
      );
    }

    // Community Forums
    match /forum-posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Partner Invites: Handled with null-safe checks for guest users
    match /invites/{inviteId} {
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow read, update: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        (request.auth.token.email != null && resource.data.receiverEmail == request.auth.token.email)
      );
      allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
    }

    // Couples & Shared Data
    match /couples/{coupleId} {
      allow read, update: if isSignedIn() && request.auth.uid in resource.data.uids;
      allow create: if isSignedIn(); 
      
      match /messages/{messageId} {
        allow read, create: if isSignedIn();
      }
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}